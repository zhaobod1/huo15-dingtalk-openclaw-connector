                  "source": {
                    "type": "string",
                    "enum": [
                      "env",
                      "file",
                      "exec"
                    ]
                  },
                  "provider": {
                    "type": "string",
                    "minLength": 1
                  },
                  "id": {
                    "type": "string",
                    "minLength": 1
